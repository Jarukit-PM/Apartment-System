{
  "name": "Apartment System (MongoDB + Go + Node)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/Apartment-System",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.24"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "remoteEnv": {
    "MONGODB_URI": "mongodb://mongo:27017"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "golang.go"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "npm ci --prefix apps/web && echo 'Web deps installed for this container OS/CPU. MONGODB_URI=mongodb://mongo:27017 in remoteEnv; host Mongo: localhost:27017 — see README.'"
}
