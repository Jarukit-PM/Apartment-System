# Copy to the repository root as `.env` and adjust. Docker Compose reads this file for substitution.
# Local dev: the Go API loads `.env` from the current working directory upward; Next.js reads only
# `API_URL` and `NEXT_PUBLIC_API_URL` from this file (see `apps/web/next.config.mjs`) so `PORT=8080`
# here does not override the Next dev server port.

# Go API (local or container)
PORT=8080
MONGODB_URI=mongodb://localhost:27017/apartment_system
# Required when MongoDB is reachable (>= 16 chars). Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Comma-separated browser origins allowed by CORS (Next.js dev server and Docker web hostname)
CORS_ORIGINS=http://localhost:3000

# Next.js — server-side fetches to the API (use service name inside Docker network)
API_URL=http://localhost:8080
# Browser / client-side API base (must be reachable from the user’s machine)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Go API — scheduled rent invoices (UTC calendar months). Set to 0 to disable. Default 3600.
# BILLING_TICK_INTERVAL_SECONDS=3600
# Go API — on-disk image uploads (local default: uploads/). Production/Docker use /data/media or /tmp/apartment-media.
# MEDIA_DIR=uploads

# --- Production (Render API + Vercel web + MongoDB Atlas) ---
# Set on Render (apartment-api): APP_ENV=production, MONGODB_URI=<Atlas SRV>, JWT_SECRET, CORS_ORIGINS=https://<your-app>.vercel.app
# Set on Vercel (apps/web): API_URL=https://<apartment-api>.onrender.com, NEXT_PUBLIC_API_URL=same if the browser calls the API
# GitHub Actions secrets: VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID, RENDER_DEPLOY_HOOK_URL — see .github/workflows/deploy.yml
